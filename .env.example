### Zalo Mini App / ZMP
# App ID (client) - có thể cần cho build/runtime
APP_ID=1781507934319376589

### Backend
PORT=10000
MONGO_URL=mongodb://127.0.0.1:27017/pinhoanglong

# Token để vào trang /admin và gọi /api/admin/*
# Đặt 1 giá trị mạnh khi deploy production
ADMIN_TOKEN=change_me_strong_token

### Zalo Open API (server-side verify access_token)
# App secret của Mini App dùng để tạo appsecret_proof khi gọi https://graph.zalo.me/v2.0/me
ZALO_APP_SECRET=change_me_app_secret

### Optional
# Danh sách origin CORS bổ sung, ngăn cách bằng dấu phẩy
# CORS_ORIGINS=https://your-domain.com,https://another-domain.com
